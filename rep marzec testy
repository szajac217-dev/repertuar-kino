    }

    body{margin:0;font-family:Arial, Helvetica, sans-serif;background:var(--bg);color:#111;}
    .moksial-repertuar{max-width:1100px;margin:0 auto;padding:12px;box-sizing:border-box;}
    .bar{height:8px;border-radius:999px;margin:6px 0 14px 0;background:linear-gradient(90deg,#e53935 0%, #fdd835 50%, #0a8f2a 100%);}
    h2{margin:0 0 12px 0;font-size:28px;line-height:1.1;}
    h2 span{background:var(--green);color:#fff;padding:8px 12px;border-radius:12px;display:inline-block;}

    .wrap{border:1px solid #e6e6e6;border-radius:14px;overflow:hidden;}
    table{width:100%;border-collapse:collapse;font-size:14px;}
    thead th{background:var(--green);color:#fff;text-align:center;padding:14px;font-size:15px;}
    tbody td{vertical-align:top;padding:16px;border-top:1px solid #eaeaea;}
    tbody tr:nth-child(even){background:#fafafa;}

    .datecol{width:34%;text-align:center;}
    .datepill{display:inline-block;padding:6px 12px;border:1px solid var(--green);border-radius:999px;color:var(--green2);font-weight:700;margin-bottom:6px;}
    .time{font-size:16px;font-weight:700;}
    .dkfTag{display:inline-block;margin-top:10px;background:#111;color:#fff;border-radius:999px;padding:6px 10px;font-weight:700;font-size:12px;}

    .filmcol{border-left:4px solid var(--red);}
    .head{display:flex;gap:10px;justify-content:space-between;align-items:flex-start;}
    .head h3{margin:0;font-size:22px;line-height:1.15;}
    .badges{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;}
    .badge{background:#ff9800;color:#fff;padding:4px 10px;border-radius:999px;font-weight:700;font-size:12px;white-space:nowrap;}
    .line{height:2px;background:var(--red);margin:10px 0 12px;}
    p{margin:4px 0;}
    strong{color:var(--green2);}

    /* UKŁAD: opis + okładka po prawej */
    .filmgrid{
      display:grid;
      grid-template-columns: 1fr 180px;
      gap:20px;
      align-items:start;
    }
    .poster-right{
      width:180px;
      aspect-ratio:2/3;
      object-fit:cover;
      border-radius:14px;
      box-shadow:0 8px 18px rgba(0,0,0,.18);
      background:#eee;
    }
    .posterHint{font-size:12px;color:var(--muted);margin-top:6px;}

    @media (max-width: 820px){
      .moksial-repertuar{padding:10px;}
      .filmgrid{grid-template-columns:1fr;}
      .poster-right{width:160px;}
      thead{display:none;}
      table, tbody, tr, td{display:block;width:100%;}
      .filmcol{border-left:none;border-top:4px solid var(--red);}
      .datecol{text-align:left;}
    }
  </style>
</head>

